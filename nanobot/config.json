{
  "providers": {
    "custom": {
      "apiKey": "qwen-code-api-key-secret",
      "apiBase": "http://localhost:42005/v1"
    }
  },
  "agents": {
    "defaults": {
      "model": "coder-model",
      "provider": "custom"
    }
  },
  "tools": {
    "mcpServers": {
      "lms": {
        "command": "python",
        "args": ["-m", "mcp_lms"],
        "env": {
          "NANOBOT_LMS_BACKEND_URL": "http://localhost:42002",
          "NANOBOT_LMS_API_KEY": "lms-api-key-secret"
        }
      }
    }
  }
}
